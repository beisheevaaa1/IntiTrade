DATABASE_URL="postgresql://intitrade:intitrade@localhost:5432/intitrade_db?schema=public"
NODE_ENV="development"
HOST="127.0.0.1"
TRUST_PROXY="1"
APP_VERSION="development"
LOG_LEVEL="info"
JWT_SECRET="replace-with-a-long-random-secret-for-production"
JWT_EXPIRES_IN="7d"
SESSION_COOKIE_MAX_AGE_SECONDS="604800"
EMAIL_VERIFICATION_REQUIRED="true"
# "screen" displays a short demo code; "email" sends a private link through SMTP.
EMAIL_VERIFICATION_DELIVERY="screen"
# Leave empty to allow any valid email. Use a comma-separated list to restrict registration.
ALLOWED_EMAIL_DOMAINS=""
CLIENT_URL="http://localhost:5173"
CLIENT_URLS=""
API_URL="http://localhost:4000"
PORT="4000"
READINESS_TIMEOUT_MS="2000"
READINESS_CACHE_MS="5000"
UPLOAD_MAX_VIDEO_MB="25"
UPLOAD_MAX_USER_MB="250"
UPLOAD_MAX_TOTAL_MB="5000"
UPLOAD_ORPHAN_TTL_HOURS="24"
SMTP_HOST="localhost"
SMTP_PORT="1025"
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM="IntiTrade <no-reply@intitrade.local>"
